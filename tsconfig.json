{
  "compilerOptions": {
    "target": "ES6",
    "module": "nodenext",
    "lib": ["esnext", "dom", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["dist"]
}
